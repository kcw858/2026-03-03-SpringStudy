package com.sist.main;

import org.springframework.context.ApplicationContext;
import org.springframework.context.support.ClassPathXmlApplicationContext;

public class MainClass {
	public static void main(String[] args) {
		//Container에 등록
		ApplicationContext app = new ClassPathXmlApplicationContext("application.xml"); //클래스 메모리 할당
		
		//등록된 컨테이너에서 클래스 객체 읽기
		Sawon sa1 = (Sawon)app.getBean("sa");
		System.out.println("sa주소값: "+sa1);
		
		Sawon sa2 = (Sawon)app.getBean("sa");
		System.out.println("sa주소값: "+sa2);
		
		if(sa1 == sa2)
		{
			System.out.println("같은 객체");
		}else
		{
			System.out.println("다른 객체");
		}
	}
}
