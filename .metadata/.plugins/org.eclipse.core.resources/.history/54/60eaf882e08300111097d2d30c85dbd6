<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- 
		public class Sawon
		{
			변수1..
			변수2..
			
			public Sawon()
		}
		
		=> 사원은 default 생성자가 있음
		
		<bean id="mem" class="com.sist.main.Member"> : default생성사를 호출, 근데 매개변수가 있는 생성자를 만들었기 때문에 매개변수를 넣어줘야한다
		public class Member
		{
			변수1..
			변수2...
			public Member(int mno,String name,String address,String phone)
			{
			
			}
		}
	 -->
	 
	 <!-- 객체가 생성, 소멸할 때 한번만 호출 -->
	<bean id="mem1" class="com.sist.main.Member"
		init-method="init" destroy-method="destory"
	>
		<constructor-arg value="1" index="0"></constructor-arg>
		<constructor-arg value="홍길동" index="1"></constructor-arg>
		<constructor-arg value="서울" index="2"></constructor-arg>
		<constructor-arg value="1111-1111" index="3"></constructor-arg>
	</bean>
	<bean id="mem2" class="com.sist.main.Member">
		<constructor-arg><value>2</value></constructor-arg>
		<constructor-arg><value>심청이</value></constructor-arg>
		<constructor-arg><value>경기</value></constructor-arg>
		<constructor-arg><value>2222-2222</value></constructor-arg>
	</bean>
	<bean id="mem3" class="com.sist.main.Member"
		c:mno="3"
		c:name="이순신"
		c:address="강원"
		c:phone="3333-3333"
	/>
	
	<!-- 보안 -->
	<bean id="mem4" class="com.sist.main.Member"
		c:_00="4"
		c:_01="이순신"
		c:_02="강원"
		c:_03="3333-3333"
	/>
</beans>
